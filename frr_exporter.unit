# -*- mode: conf -*-

[Unit]
Description=Prometheus exporter for FRR metrics
Documentation=https://github.com/tynany/frr_exporter
After=network.target

[Service]
EnvironmentFile=-/etc/default/frr_exporter
User=frr
ExecStart=/usr/bin/frr_exporter $FRR_EXPORTER_OPTS
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5s


[Install]
WantedBy=multi-user.target
